{
  "version": "1.0.0-alpha.6",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "dom.asynciterable", "deno.ns"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["vite/client"]
  },
  "exclude": ["**/_fresh/*"],
  "fmt": {
    "exclude": [".git-hooks/", "assets/", "static/"],
    "include": ["./"],
    "indentWidth": 2,
    "lineWidth": 80,
    "semiColons": true
  },
  "imports": {
    "$std/": "https://deno.land/std@0.216.0/",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@splinetool/runtime": "npm:@splinetool/runtime@^1.8.9",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5",
    "preact": "npm:preact@^10.29.1",
    "preact/": "https://esm.sh/preact@10.22.0/",
    "std/path": "https://deno.land/std@0.121.0/path/mod.ts",
    "tailwindcss": "npm:tailwindcss@3.4.1",
    "tailwindcss/": "npm:/tailwindcss@3.4.1/",
    "tailwindcss/plugin": "npm:/tailwindcss@3.4.1/plugin.js",
    "vite": "npm:vite@^8.0.16"
  },
  "lint": {
    "rules": { "tags": ["fresh", "recommended"] },
    "exclude": ["assets/fonts/", "static/fonts/"],
    "include": ["./**/*.ts"]
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check",
    "format": "deno fmt",
    "update": "deno run -A -r jsr:@fresh/update .",
    "dev": "vite",
    "build": "vite build",
    "start": "deno run -A _fresh/server.js"
  }
}
