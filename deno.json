{
  "version": "1.0.0-alpha.6",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "dom.asynciterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  },
  "exclude": ["**/_fresh/*"],
  "fmt": {
    "exclude": [".git-hooks/", "assets/", "static/"],
    "include": ["./"],
    "indentWidth": 2,
    "lineWidth": 80,
    "semiColons": true
  },
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.1",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "vite": "npm:vite@^7.1.3",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "@splinetool/runtime": "npm:@splinetool/runtime@^1.8.9"
  },
  "lint": {
    "rules": { "tags": ["fresh", "recommended"] },
    "exclude": ["assets/", "static/"],
    "include": ["./**/*.ts", "./**/*.tsx"]
  },
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check",
    "format": "deno fmt",
    "update": "deno run -A -r jsr:@fresh/update .",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js"
  }
}
